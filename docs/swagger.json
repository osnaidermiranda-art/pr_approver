{
    "swagger": "2.0",
    "info": {
        "description": "Service to approve and merge GitHub pull requests",
        "title": "PR Approved API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/git-hub": {
            "post": {
                "description": "Approve, merge, or approve and merge a GitHub pull request from the G97-TECH-MKT organization.\nIf no action is provided, defaults to \"both\" (approve + squash merge).\n\n**Allowed actions:**\n- `approve` — Approves the pull request\n- `merge` — Squash merges the pull request\n- `both` — Approves and then squash merges (default)\n\n**URL format:** `https://github.com/G97-TECH-MKT/{repo}/pull/{number}`",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "pull-requests"
                ],
                "summary": "Perform actions on a GitHub pull request",
                "parameters": [
                    {
                        "description": "Pull request action payload",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/GitHubRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Action completed successfully",
                        "schema": {
                            "$ref": "#/definitions/SuccessResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid URL, repository, or action",
                        "schema": {
                            "$ref": "#/definitions/ErrorResponse"
                        }
                    },
                    "405": {
                        "description": "Method not allowed (only POST)",
                        "schema": {
                            "$ref": "#/definitions/ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Failed to approve or merge the pull request",
                        "schema": {
                            "$ref": "#/definitions/ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "ErrorResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string",
                    "example": "Invalid action"
                },
                "status": {
                    "type": "string",
                    "example": "error"
                }
            }
        },
        "GitHubRequest": {
            "type": "object",
            "properties": {
                "action": {
                    "type": "string",
                    "enum": [
                        "approve",
                        "merge",
                        "both"
                    ],
                    "example": "both"
                },
                "url": {
                    "type": "string",
                    "example": "https://github.com/G97-TECH-MKT/my-repo/pull/42"
                }
            }
        },
        "SuccessResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string",
                    "example": "Pull request approved and merged"
                },
                "status": {
                    "type": "string",
                    "example": "success"
                }
            }
        }
    }
}